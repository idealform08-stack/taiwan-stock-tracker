name: 每日外資資料更新

on:
  schedule:
    - cron: '50 6 * * 1-5'
  workflow_dispatch:

permissions:
  contents: write

jobs:
  fetch:
    runs-on: ubuntu-latest
    steps:
      - name: 取得程式碼
        uses: actions/checkout@v4

      - name: 安裝 Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: 安裝依賴
        run: pip install requests

      - name: 執行爬蟲
        run: python fetch_twse.py --no-enrich

      - name: 提交資料更新
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add data/
          git diff --staged --quiet || git commit -m "每日更新：$(date '+%Y-%m-%d')"
          git push
